# Postgres
POSTGRES_USER=leap
POSTGRES_PASSWORD=leap
POSTGRES_DB=leap
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_CONNECTION_STRING=postgresql+asyncpg://leap:leap@postgres:5432/leap

# App
LOG_LEVEL=INFO
ENVIRONMENT=development
SEED_ON_STARTUP=true

# Wikipedia Speed Run (optional)
WIKI_BACK_BUTTON_ENABLED=false

# Server (optional; env vars override these)
# API_HOST=0.0.0.0
# API_PORT=8000
# API_WORKERS=4
# API_WORKER_TIMEOUT=120
